// Hylius Dashboard — Managed-Hosted Control Plane Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}


// ─── Enums & Types ─────────────────────────────────────────
// Note: SQLite does not support native enums. 
// We use Strings for roles, statuses, and providers.

// ─── Multi-Tenancy ─────────────────────────────────────────

model Organization {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  plan          String         @default("FREE") // FREE | PRO | ENTERPRISE
  isActive      Boolean        @default(true)
  users         User[]
  servers       Server[]
  projects      Project[]
  apiTokens     ApiToken[]
  subscriptions Subscription[]
  payments      Payment[]
  auditLogs     AuditLog[]
  databases     Database[]
  githubInstallations GitHubInstallation[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// ─── Auth ───────────────────────────────────────────────────

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  password       String        // bcrypt hashed
  role           String        @default("OWNER") // OWNER | ADMIN | MEMBER | PLATFORM_ADMIN
  isActive       Boolean       @default(true)
  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?       // Optional for PLATFORM_ADMIN
  sessions       Session[]
  lastLoginAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  
  @@index([organizationId])
}

model Session {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  @@index([userId])
}

model ApiToken {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  name           String
  hashedToken    String       @unique
  lastUsedAt     DateTime?
  createdAt      DateTime     @default(now())

  @@index([organizationId])
}

// ─── Audit & Billing ────────────────────────────────────────

model AuditLog {
  id             String   @id @default(cuid())
  action         String
  userId         String?
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  ipAddress      String?
  metadata       String?  // JSON string
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([userId])
  @@index([createdAt])
}

model Subscription {
  id                 String       @id @default(cuid())
  organizationId     String
  provider           String       // "STRIPE" | "PAYSTACK" | "FLUTTERWAVE"
  externalCustomerId String
  externalSubId      String
  status             String       // "ACTIVE" | "PAST_DUE" | "CANCELED" | "INCOMPLETE" | "TRIALING"
  currentPeriodEnd   DateTime?
  
  // Billing identifiers
  flutterwaveCustomerId     String?
  flutterwavePaymentMethodId String?

  planId             String?
  plan               Plan?        @relation(fields: [planId], references: [id])
  organization       Organization @relation(fields: [organizationId], references: [id])

  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([organizationId])
}

model Payment {
  id                     String       @id @default(cuid())
  organizationId         String
  provider               String       // "STRIPE" | "PAYSTACK" | "FLUTTERWAVE"
  externalTransactionId  String       @unique
  amount                 Float
  currency               String       @default("USD")
  status                 String       // "SUCCESS" | "FAILED" | "PENDING"
  
  organization           Organization @relation(fields: [organizationId], references: [id])
  createdAt              DateTime     @default(now())

  @@index([organizationId])
  @@index([externalTransactionId])
}

model Plan {
  id                String         @id @default(cuid())
  name              String
  description       String?
  amount            Float
  currency          String         @default("USD")
  interval          String         @default("MONTHLY") // MONTHLY | YEARLY
  
  paystackPlanCode  String?        @unique
  flutterwavePlanId String?        @unique
  
  isActive          Boolean        @default(true)
  subscriptions     Subscription[]
  
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}


// ─── Infrastructure ─────────────────────────────────────────

model Server {
  id                  String       @id @default(cuid())
  name                String
  ip                  String
  port                Int          @default(22)
  username            String
  privateKeyEncrypted String?      // AES-256-GCM encrypted SSH key (managed)
  keyIv               String?      // Initialization vector for decryption
  osType              String?      // e.g. "Ubuntu", "Alpine"
  // ─── Agent fields ──────────────────────────────────────────────────────────
  agentToken          String?      @unique   // Per-server token for agent auth
  agentVersion        String?               // e.g. "0.1.0"
  connectionMode      String       @default("SSH")      // "SSH" | "AGENT"
  status              String       @default("UNKNOWN")  // "ONLINE" | "OFFLINE" | "UNKNOWN"
  lastHeartbeatAt     DateTime?             // Last successful heartbeat from agent
  // ───────────────────────────────────────────────────────────────────────────
  organization        Organization @relation(fields: [organizationId], references: [id])
  organizationId      String
  projects            Project[]
  metrics             Metric[]
  databases           Database[]
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([organizationId])
  @@index([agentToken])
}


model Project {
  id             String       @id @default(cuid())
  name           String
  repoUrl        String
  branch         String       @default("main")
  deployPath     String
  buildCommand   String?
  startCommand   String?
  envVars        String?      // JSON string of env vars
  deployStrategy String?      // 'auto' | 'pm2' | 'docker-compose' | 'dockerfile' | 'railpack' | 'nixpacks' | 'ghcr-pull' | 'dagger' | 'compose-registry' | 'compose-server'
  ghcrImage      String?      // e.g. 'ghcr.io/isaac-hash/my-app:latest'
  githubRepoFullName    String?   // e.g. "user/repo" — links to GitHub App webhook
  githubInstallationId  Int?      // GitHub App installation ID for this repo
  isTemplate     Boolean      @default(false)
  templateId     String?
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  server         Server       @relation(fields: [serverId], references: [id])
  serverId       String
  deployments    Deployment[]
  domains        Domain[]
  databases      Database[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([serverId])
}

model Deployment {
  id             String       @id @default(cuid())
  releaseId      String       // Core-generated timestamp ID
  commitHash     String?
  environment    String       @default("PRODUCTION") // "PRODUCTION" | "PREVIEW"
  pullRequestNumber Int?      // The GitHub PR number if this is a preview deployment
  status         String       // "PENDING" | "BUILDING" | "SUCCESS" | "FAILED"
  triggerSource  String       // "CLI" | "DASHBOARD" | "WEBHOOK"
  durationMs     Int?
  logPath        String?      // Path to log file / object storage key
  logContent     String?      // Full buffered text output
  deployUrl      String?      // Live URL where the deployed app is accessible
  project        Project      @relation(fields: [projectId], references: [id])
  projectId      String
  organizationId String?      // For faster aggregation queries (admin level)
  startedAt      DateTime     @default(now())
  finishedAt     DateTime?

  @@index([projectId])
  @@index([organizationId])
  @@index([startedAt])
}

model Domain {
  id             String   @id @default(cuid())
  hostname       String   @unique // e.g. "myapp.com" or "api.myapp.com"
  status         String   @default("PENDING") // PENDING | DNS_VERIFIED | ACTIVE | ERROR
  sslStatus      String   @default("PENDING") // PENDING | PROVISIONING | ACTIVE | ERROR
  errorMessage   String?
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([projectId])
}

model GitHubInstallation {
  id               String       @id @default(cuid())
  installationId   Int          @unique   // GitHub's numeric installation ID
  accountLogin     String                 // GitHub user/org login
  accountType      String                 // "User" | "Organization"
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id])
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([organizationId])
}

model Metric {
  id        String   @id @default(cuid())
  server    Server   @relation(fields: [serverId], references: [id])
  serverId  String
  cpu       Float
  memory    Float
  disk      Float
  uptime    Float
  createdAt DateTime @default(now())

  @@index([serverId])
}

// ─── Database Management ─────────────────────────────────────────────────────

model Database {
  id                String       @id @default(cuid())
  name              String                          // User-friendly name, e.g. "my-app-db"
  engine            String                          // "POSTGRES" | "MYSQL" | "REDIS"
  version           String       @default("latest") // Docker tag, e.g. "16", "8", "7"
  status            String       @default("PENDING") // "PENDING" | "PROVISIONING" | "RUNNING" | "STOPPED" | "ERROR"
  containerName     String?                         // Docker container name on VPS
  port              Int?                            // Host port mapped to container (auto-assigned)
  dbName            String?                         // Database name inside the engine
  dbUser            String?                         // Username for the database
  passwordEncrypted String?                         // AES-256-GCM encrypted password
  passwordIv        String?                         // IV for decryption
  errorMessage      String?

  server            Server       @relation(fields: [serverId], references: [id])
  serverId          String
  project           Project?     @relation(fields: [projectId], references: [id])
  projectId         String?
  organization      Organization @relation(fields: [organizationId], references: [id])
  organizationId    String

  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([serverId])
  @@index([projectId])
  @@index([organizationId])
}
