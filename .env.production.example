# ============================================================
# Hylius Dashboard — Production Environment
# Copy this file to .env on your VPS and fill in values.
# ============================================================

# App URL — set to http://YOUR_VPS_IP until a domain is configured
NEXT_PUBLIC_APP_URL=http://YOUR_VPS_IP

# ─── Database ─────────────────────────────────────────────────
# PostgreSQL — used by the dashboard container
# The DATABASE_URL is constructed automatically by compose.yaml
# from the variables below; you don't need to set it manually.
POSTGRES_USER=hylius
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=hylius

# ─── Security ──────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS

# ─── TLS Mode ─────────────────────────────────────────────────
# "production" = Let's Encrypt (requires a domain)
# "internal" = self-signed (use for IP-only access)
HYLIUS_TLS_MODE=internal

# ─── Stripe ────────────────────────────────────────────────────
STRIPE_PUBLIC_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Paystack ─────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_PUBLIC_KEY=pk_live_...

# ─── Flutterwave ──────────────────────────────────────────────
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-...
FLUTTERWAVE_SECRET_KEY=FLWSECK-...
FLUTTERWAVE_ENCRYPTION_KEY=...
FLUTTERWAVE_WEBHOOK_SECRET=...

# ─── GitHub App ────────────────────────────────────────────────
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
# Base64-encoded PEM private key
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
NEXT_PUBLIC_GITHUB_APP_SLUG=hylius-platform
